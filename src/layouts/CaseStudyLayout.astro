---
import BaseLayout from './BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  titleEs?: string;
  client: string;
  role: string;
  roleEs?: string;
  period: string;
  problem: string;
  problemEs?: string;
  solution: string;
  solutionEs?: string;
  result: string;
  resultEs?: string;
  tech: string[];
  bodyEs?: string;
  links?: { label: string; url: string }[];
}

const { title, titleEs, client, role, roleEs, period, problem, problemEs, solution, solutionEs, result, resultEs, tech, bodyEs, links } = Astro.props;
---

<BaseLayout title={`${title} | Danny Barahona`} description={problem}>
  <Navbar />
  <main class="container" style={`padding-top: calc(var(--navbar-height) + var(--space-2xl)); padding-bottom: var(--space-4xl);`}>
    <a href="/#cases" class="back-link" data-i18n="detail.back.cases">&larr; Back to work</a>

    <article>
      <header class="case-header">
        <h1 class="lang-en">{title}</h1>
        {titleEs && <h1 class="lang-es" style="display:none;">{titleEs}</h1>}
        <p class="case-client">{client}</p>
        <div class="case-meta">
          <div class="case-meta__item">
            <span class="case-meta__label" data-i18n="detail.role">Role</span>
            <span class="case-meta__value lang-en">{role}</span>
            {roleEs && <span class="case-meta__value lang-es" style="display:none;">{roleEs}</span>}
          </div>
          <div class="case-meta__item">
            <span class="case-meta__label" data-i18n="detail.period">Period</span>
            <span class="case-meta__value">{period}</span>
          </div>
        </div>
      </header>

      <div class="case-summary">
        <div class="case-summary__block">
          <h3 data-i18n="detail.problem">The Problem</h3>
          <p class="lang-en">{problem}</p>
          {problemEs && <p class="lang-es" style="display:none;">{problemEs}</p>}
        </div>
        <div class="case-summary__block">
          <h3 data-i18n="detail.solution">The Solution</h3>
          <p class="lang-en">{solution}</p>
          {solutionEs && <p class="lang-es" style="display:none;">{solutionEs}</p>}
        </div>
        <div class="case-summary__block case-summary__block--highlight">
          <h3 data-i18n="detail.result">The Result</h3>
          <p class="lang-en">{result}</p>
          {resultEs && <p class="lang-es" style="display:none;">{resultEs}</p>}
        </div>
      </div>

      <div class="case-tech">
        <h3 data-i18n="detail.tech">Technologies</h3>
        <div class="tags">
          {tech.map((t) => (
            <span class="badge badge--accent">{t}</span>
          ))}
        </div>
      </div>

      {links && links.length > 0 && (
        <div class="case-links">
          <h3 data-i18n="detail.links">Links</h3>
          <div class="case-links__list">
            {links.map((link) => (
              <a href={link.url} target="_blank" rel="noopener noreferrer" class="case-links__item">
                {link.label.includes('App Store') && (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
                )}
                {link.label.includes('Google Play') && (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M3.18 23.67c-.37-.2-.55-.63-.55-1.24V1.57c0-.61.18-1.04.55-1.24L13.92 12 3.18 23.67zm1.4.96l12.4-7.15-2.76-2.76L4.58 24.63zM20.16 13.12l-3.12 1.8-2.98-2.98 2.98-2.92 3.12 1.8c.93.52.93 1.78 0 2.3zM4.58-.63L16.22 9.29 18.98 6.52 4.58-.63z"/></svg>
                )}
                {link.label.includes('Web') && (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>
                )}
                <span>{link.label}</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
              </a>
            ))}
          </div>
        </div>
      )}

      <div class="prose lang-en">
        <slot />
      </div>
      {bodyEs && (
        <div class="prose lang-es" style="display:none;" set:html={bodyEs} />
      )}
    </article>
  </main>
  <Footer />

  <script>
    function applyCaseStudyLang() {
      const lang = localStorage.getItem('lang') || (navigator.language?.slice(0, 2) === 'es' ? 'es' : 'en');
      document.querySelectorAll('.lang-en').forEach(el => {
        (el as HTMLElement).style.display = lang === 'en' ? '' : 'none';
      });
      document.querySelectorAll('.lang-es').forEach(el => {
        (el as HTMLElement).style.display = lang === 'es' ? '' : 'none';
      });
    }

    applyCaseStudyLang();
    document.addEventListener('language-change', applyCaseStudyLang);
  </script>
</BaseLayout>

<style>
  .case-header {
    margin-bottom: var(--space-2xl);
  }

  .case-header h1 {
    margin-bottom: var(--space-xs);
  }

  .case-client {
    font-size: var(--font-size-lg);
    color: var(--color-accent);
    margin-bottom: var(--space-lg);
  }

  .case-meta {
    display: flex;
    gap: var(--space-2xl);
    flex-wrap: wrap;
  }

  .case-meta__label {
    display: block;
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-xs);
  }

  .case-meta__value {
    font-weight: 600;
    color: var(--color-text);
  }

  .case-summary {
    display: grid;
    gap: var(--space-lg);
    margin-bottom: var(--space-2xl);
  }

  @media (min-width: 768px) {
    .case-summary {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .case-summary__block {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: var(--space-xl);
  }

  .case-summary__block h3 {
    margin-bottom: var(--space-sm);
    font-size: var(--font-size-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  .case-summary__block p {
    color: var(--color-text);
    font-size: var(--font-size-sm);
    line-height: 1.6;
  }

  .case-summary__block--highlight {
    border-color: var(--color-accent);
    background: rgba(124, 58, 237, 0.05);
  }

  .case-tech {
    margin-bottom: var(--space-2xl);
  }

  .case-tech h3 {
    margin-bottom: var(--space-md);
  }

  .case-links {
    margin-bottom: var(--space-2xl);
  }

  .case-links h3 {
    margin-bottom: var(--space-md);
  }

  .case-links__list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .case-links__item {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-xs) var(--space-md);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface);
    color: var(--color-text);
    text-decoration: none;
    font-size: var(--font-size-sm);
    transition: border-color var(--transition), color var(--transition);
  }

  .case-links__item:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .case-links__item svg {
    flex-shrink: 0;
  }
</style>
