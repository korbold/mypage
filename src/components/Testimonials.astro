<section class="section">
  <div class="container">
    <h2 class="section-title reveal" data-i18n="testimonials.title">What people say</h2>
    <div class="testimonial reveal reveal-delay-1">
      <blockquote>
        <p class="testimonial__quote" data-i18n="testimonials.quote">
          &ldquo;Danny delivered the Flutter modules on time, with clean code and great communication throughout the project.&rdquo;
