    padding-left: var(--space-xl);
  }

  .testimonial__quote {
    font-size: var(--font-size-xl);
    color: var(--color-text);
    line-height: 1.6;
    font-style: italic;
    margin-bottom: var(--space-md);
  }

  .testimonial__author {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    font-style: normal;
  }
</style>
