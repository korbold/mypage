---
interface Props {
  title: string;
  client: string;
  role: string;
  result: string;
  tech: string[];
  slug: string;
}

const { title, client, role, result, tech, slug } = Astro.props;
---

<a href={`/case-studies/${slug}`} class="case-card card">
  <div class="case-card__header">
    <span class="case-card__client">{client}</span>
    <span class="case-card__role">{role}</span>
  </div>
  <h3 class="case-card__title">{title}</h3>
  <p class="case-card__result">{result}</p>
  <div class="tags">
    {tech.slice(0, 4).map((t) => (
      <span class="badge">{t}</span>
    ))}
    {tech.length > 4 && <span class="badge">+{tech.length - 4}</span>}
  </div>
  <span class="case-card__link" data-i18n="cases.view">View case study &rarr;</span>
</a>

<style>
  .case-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    text-decoration: none;
    color: inherit;
  }

  .case-card__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .case-card__client {
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--color-accent);
  }

  .case-card__role {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
  }

  .case-card__title {
    font-size: var(--font-size-lg);
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-text);
  }

  .case-card__result {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .case-card__link {
    font-size: var(--font-size-sm);
    font-weight: 500;
    color: var(--color-accent);
    margin-top: auto;
    transition: color var(--transition);
  }

  .case-card:hover .case-card__link {
    color: var(--color-secondary);
  }
</style>
