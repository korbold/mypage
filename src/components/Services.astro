---
---

<section id="services" class="section">
  <div class="container">
    <h2 class="section-title reveal" data-i18n="services.title">What I do</h2>
    <div class="grid-3">
      <!-- Mobile Apps -->
      <div class="card reveal reveal-delay-1">
        <div class="service-icon">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="5" y="2" width="14" height="20" rx="2" ry="2"/>
            <line x1="12" y1="18" x2="12" y2="18.01"/>
          </svg>
        </div>
        <h3 data-i18n="services.mobile.title">Mobile Apps</h3>
        <p data-i18n="services.mobile.desc">End-to-end Flutter apps for iOS & Android. Clean architecture, Firebase, App Store deployment.</p>
      </div>

      <!-- Backend & APIs -->
      <div class="card reveal reveal-delay-2">
        <div class="service-icon">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
            <line x1="8" y1="21" x2="16" y2="21"/>
            <line x1="12" y1="17" x2="12" y2="21"/>
          </svg>
        </div>
        <h3 data-i18n="services.backend.title">Backend & APIs</h3>
        <p data-i18n="services.backend.desc">Scalable APIs with NestJS/Node.js. Auth with OAuth2/Keycloak, Docker, CI/CD pipelines.</p>
      </div>

      <!-- Cloud & DevOps -->
      <div class="card reveal reveal-delay-3">
        <div class="service-icon">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 10h-1.26A8 8 0 109 20h9a5 5 0 000-10z"/>
          </svg>
        </div>
        <h3 data-i18n="services.cloud.title">Cloud & DevOps (AWS)</h3>
        <p data-i18n="services.cloud.desc">Production-grade AWS infrastructure: ECS, EKS, Lambda, Aurora, RDS. High availability by default.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .service-icon {
    color: var(--color-accent);
    margin-bottom: var(--space-md);
  }

  .card h3 {
    margin-bottom: var(--space-sm);
  }

  .card p {
    font-size: var(--font-size-sm);
    line-height: 1.6;
  }
</style>
